# Use a modern Node version that supports Vite
FROM node:22-slim

WORKDIR /app

# Copy package files first to leverage Docker's cache
COPY package.json ./
COPY package-lock.json* ./

# Install dependencies
RUN npm install

# Copy the rest of the frontend code
COPY . .

# Vite's default dev port
EXPOSE 3000

# Start Vite and tell it to listen on all interfaces (0.0.0.0)
# so it's reachable from outside the container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]