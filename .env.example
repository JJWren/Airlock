# --- AIRLOCK / PROVENANCE ENVIRONMENT TEMPLATE ---
# Instructions: Copy this file to a new file named '.env' and replace the placeholders.

# 1. SECURITY & API KEYS
# Request your key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=YOUR_NIST_API_KEY_HERE

# 2. FASTAPI CONFIGURATION
APP_NAME="Airlock"
APP_VERSION="1.0.0"
DEBUG=True
API_V1_STR="/api/v1"

# 3. DOCKER / SYSTEM PATHS
# Windows local path to your source code or scan targets
SCAN_UPLOAD_PATH="C:/path/to/your/source"

# Path to the Syft binary (Relative to project root for local dev)
SYFT_BINARY_PATH="bin/syft.exe"

# 4. LOGGING
LOG_LEVEL=INFO

# --- NETWORK SETTINGS ---
# The port you hit in your browser (Change this if 8000 is taken)
AIRLOCK_API_EXTERNAL_PORT=8000

# The port FastAPI uses inside the container (Matches your code)
AIRLOCK_API_INTERNAL_PORT=8000

# 5. CORS SETTINGS
# Comma-separated list of allowed origins
ALLOWED_HOSTS='["http://localhost,http://localhost:8000,http://localhost:3000"]'
